{
  "name": "Flock",
  "homepage": "https://flockxr.com",
  "version": "1.0.0",
  "scripts": {
    "dev": "vite",
    "build": "node --max-old-space-size=4096 node_modules/vite/bin/vite.js build",
    "serve": "vite preview",
    "lint": "eslint . && npm run check:link-security",
    "check:link-security": "node scripts/check-link-security.mjs",
    "test:api": "node scripts/run-api-tests.mjs",
    "test:api:watch": "node scripts/run-api-tests.mjs --watch",
    "test:input": "node scripts/run-input-tests.mjs",
    "test:microbit": "node scripts/run-microbit-tests.mjs",
    "test:gizmos": "node scripts/run-api-tests.mjs gizmos",
    "docs:coverage": "node scripts/api-coverage-report.mjs",
    "docs:matrix": "node scripts/test-coverage-matrix.mjs",
    "validate:api-docs": "node scripts/validate-api-docs.mjs",
    "test:csp-smoke": "node scripts/csp-smoke.mjs",
    "format:check": "prettier --check .",
    "format": "prettier --write ."
  },
  "dependencies": {
    "@babylonjs/addons": "^8.56.0",
    "@babylonjs/core": "^8.56.0",
    "@babylonjs/gui": "^8.56.0",
    "@babylonjs/gui-editor": "^8.56.0",
    "@babylonjs/havok": "^1.3.12",
    "@babylonjs/loaders": "^8.56.0",
    "@babylonjs/materials": "^8.56.0",
    "@babylonjs/serializers": "^8.56.0",
    "@blockly/block-dynamic-connection": "^13.1.0",
    "@blockly/block-plus-minus": "^13.1.0",
    "@blockly/field-colour": "^13.1.0",
    "@blockly/field-grid-dropdown": "^13.1.0",
