    "@blockly/plugin-workspace-search": "^13.1.0",
    "@blockly/toolbox-search": "^13.1.0",
    "@fontsource/asap": "^5.2.9",
    "@fontsource/atkinson-hyperlegible-next": "^5.2.7",
    "@microbit/microbit-connection": "^0.1.0",
    "acorn": "^8.16.0",
    "acorn-walk": "^8.3.5",
    "babylonjs": "^8.56.0",
    "babylonjs-gui": "^8.56.0",
    "babylonjs-serializers": "^8.56.0",
    "blockly": "^13.1.0",
    "earcut": "^3.0.2",
    "manifold-3d": "^3.5.0",
