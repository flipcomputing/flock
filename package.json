  "devDependencies": {
    "@babylonjs/inspector": "8.42.0",
    "@eslint/js": "^9.39.2",
    "@isaacs/brace-expansion": "^5.0.1",
    "@playwright/test": "^1.58.2",
    "@types/estree": "^1.0.8",
    "ajv": "^8.18.0",
    "chai": "^6.2.2",
    "eslint": "^10.0.3",
    "ffmpeg": "^0.0.4",
    "globals": "^16.5.0",
    "lodash": "^4.17.23",
    "meta-png": "^1.0.6",
    "mocha": "^11.3.0",
    "playwright": "^1.58.2",
    "prettier": "^3.8.1",
    "vite": "^8.0.16",
    "vite-plugin-pwa": "^1.2.0",
    "vite-plugin-static-copy": "^3.3.0"
